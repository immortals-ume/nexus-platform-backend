<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>application</includeMdcKeyName>
            <includeMdcKeyName>profile</includeMdcKeyName>
            <customFields>{"service":"config-service"}</customFields>
        </encoder>
    </appender>

    <appender name="CONSOLE_STANDARD" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{correlationId:-NO_CORRELATION_ID}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/config-service.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/config-service.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>application</includeMdcKeyName>
            <includeMdcKeyName>profile</includeMdcKeyName>
            <customFields>{"service":"config-service"}</customFields>
        </encoder>
    </appender>

    <springProfile name="dev,local">
        <root level="INFO">
            <appender-ref ref="CONSOLE_STANDARD"/>
        </root>
        <logger name="com.example.config_server" level="DEBUG"/>
    </springProfile>
    
    <springProfile name="staging,prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.example.config_server" level="INFO"/>
    </springProfile>

    <springProfile name="!dev &amp; !local &amp; !staging &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
        <logger name="com.example.config_server" level="INFO"/>
    </springProfile>

    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.cloud.config" level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.apache.kafka" level="WARN"/>
</configuration>
