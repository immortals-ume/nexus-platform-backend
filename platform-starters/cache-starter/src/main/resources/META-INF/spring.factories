# Auto-configuration classes for cache starter (Spring Boot 2.x compatibility)
org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
com.immortals.platform.cache.config.CacheAutoConfiguration,\
com.immortals.platform.cache.config.CaffeineAutoConfiguration,\
com.immortals.platform.cache.config.RedisAutoConfiguration,\
com.immortals.platform.cache.config.RedisHashAutoConfiguration,\
com.immortals.platform.cache.config.MultiLevelAutoConfiguration,\
com.immortals.platform.cache.config.DecoratorAutoConfiguration,\
com.immortals.platform.cache.config.CacheAnnotationAutoConfiguration,\
com.immortals.platform.cache.config.CacheObservabilityAutoConfiguration